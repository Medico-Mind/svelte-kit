{
	"name": "@medicomind/svelte-adapter-hono",
	"version": "0.2.0",
	"description": "SvelteKit adapter that builds a standalone Node server powered by Hono, with brotli/gzip/zstd precompression",
	"keywords": [
		"sveltekit",
		"svelte",
		"adapter",
		"hono",
		"node",
		"precompress",
		"brotli",
		"zstd"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup && tsc -p tsconfig.build.json",
		"check": "tsc --noEmit",
		"test": "npm run build && vitest run --coverage",
		"test:unit": "vitest run tests/unit",
		"test:watch": "vitest",
		"test:perf": "vitest run --config vitest.perf.config.ts"
	},
	"dependencies": {
		"@medicomind/rolldown-compression": "^0.3.1",
		"rolldown": "^1.1.4"
	},
	"peerDependencies": {
		"@hono/node-server": "^2.0.0",
		"@sveltejs/kit": "^2.22.0",
		"hono": "^4.6.0"
	},
	"devDependencies": {
		"@hono/node-server": "^2.0.0",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/autocannon": "^7.12.7",
		"@types/node": "^26.0.0",
		"@vitest/coverage-v8": "^4.0.0",
		"autocannon": "^8.0.0",
		"hono": "^4.12.0",
		"svelte": "^5.0.0",
		"tsup": "^8.3.0",
		"typescript": "^6.0.0",
		"vite": "^8.0.0",
		"vitest": "^4.0.0"
	},
	"engines": {
		"node": ">=22.15"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Medico-Mind/svelte-kit.git",
		"directory": "packages/adapter-hono"
	},
	"homepage": "https://github.com/Medico-Mind/svelte-kit/tree/main/packages/adapter-hono#readme",
	"bugs": "https://github.com/Medico-Mind/svelte-kit/issues"
}
