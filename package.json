{
	"name": "@medicomind/svelte-kit",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"build": "npm run build --workspace @medicomind/svelte-adapter-hono",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"check": "npm run check --workspaces --if-present",
		"test": "npm test --workspace @medicomind/svelte-adapter-hono",
		"test:unit": "npm run test:unit --workspace @medicomind/svelte-adapter-hono",
		"test:perf": "npm run test:perf --workspace @medicomind/svelte-adapter-hono",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "npm run build && changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.0",
		"@eslint/js": "^10.0.0",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.0",
		"prettier": "^3.6.0",
		"typescript-eslint": "^8.24.0"
	},
	"engines": {
		"node": ">=20.19"
	},
	"allowScripts": {
		"esbuild@0.27.7": true
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Medico-Mind/svelte-kit.git"
	}
}
